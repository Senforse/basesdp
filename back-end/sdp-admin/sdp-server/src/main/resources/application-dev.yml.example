# 复制为 application-dev.yml 或通过环境变量 SDP_DB_* 注入（勿将含真实密码的文件提交 Git）
debug: false

spring:
  datasource:
    type: com.alibaba.druid.pool.DruidDataSource
    url: jdbc:dm://192.168.204.111:5236?schema=SDPDBA&compatibleMode=oracle&useUnicode=true&characterEncoding=UTF-8
    username: ${SDP_DB_USERNAME:sdpdba}
    password: ${SDP_DB_PASSWORD:请在此填写或设置环境变量}
    driver-class-name: dm.jdbc.driver.DmDriver
    druid:
      initial-size: 5
      max-active: 20
      min-idle: 5
      max-wait: 60000
      time-between-eviction-runs-millis: 60000
      min-evictable-idle-time-millis: 300000
      validation-query: SELECT 1 FROM DUAL
      test-while-idle: true
      test-on-borrow: false
      test-on-return: false
      pool-prepared-statements: true
      max-pool-prepared-statement-per-connection-size: 20
      filters: stat
      use-global-data-source-stat: true
      connection-properties: druid.stat.mergeSql=true;druid.stat.slowSqlMillis=500
  cache:
    type: caffeine
    caffeine:
      spec: maximumSize=1000,expireAfterWrite=10m
  autoconfigure:
    exclude: org.springframework.boot.autoconfigure.amqp.RabbitAutoConfiguration
  data:
    redis:
      host: ${SDP_REDIS_HOST:127.0.0.1}
      port: ${SDP_REDIS_PORT:6379}
      database: 0

sa-token:
  token-name: satoken
  timeout: 86400
  active-timeout: -1
  is-concurrent: true
  is-share: false
  token-style: uuid
  is-log: false
