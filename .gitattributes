*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.json text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.py text eol=lf
