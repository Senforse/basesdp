# 复制到测试服务器 /opt/sdp/.env 并填写真实值（勿提交 Git）
#
# 说明：Sdp 使用独立 Docker 网络与专用端口，不会占用或修改宿主机已有 Redis / Nginx。

REGISTRY=192.168.204.111:5050/your-group/sdp
IMAGE_TAG=latest
DB_USER=sdpdba
